{
  "name": "musicphone",
  "private": true,
  "version": "1.0.0",
  "description": "MusicPhone - a collaborative real-time music game (Gartic Phone, but with melodies).",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:server": "bun --filter @musicphone/server dev",
    "dev:web": "bun --filter @musicphone/web dev",
    "build": "bun --filter '*' build",
    "typecheck": "bun --filter '*' typecheck"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
